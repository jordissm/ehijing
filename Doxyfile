# Doxyfile for the eHIJING generator.

PROJECT_NAME           = "eHIJING"
PROJECT_BRIEF          = "DIS event generation, medium modification, hadronization, and OSCAR output"
OUTPUT_DIRECTORY       = docs/doxygen

INPUT                  = README.md \
                         docs/mainpage.md \
                         include \
                         src
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp \
                         *.cpp \
                         *.md
EXCLUDE                = docs/doxygen
USE_MDFILE_AS_MAINPAGE = docs/mainpage.md

FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .

MARKDOWN_SUPPORT       = YES
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = NO
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
WARN_AS_ERROR          = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
SEARCHENGINE           = YES
HTML_DYNAMIC_SECTIONS  = YES

GENERATE_LATEX         = NO
GENERATE_XML           = NO

USE_MATHJAX            = YES
MATHJAX_FORMAT         = HTML-CSS

SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

HAVE_DOT               = YES
CLASS_DIAGRAMS         = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES

PREDEFINED             = __cplusplus=201703L
ALIASES                = "configkey=@par Config key^^"
